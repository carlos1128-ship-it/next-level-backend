# Required
# For remote Postgres providers like Neon/Render, prefer:
# DATABASE_URL="postgresql://user:password@host/db?schema=public&sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/next_level_db?schema=public"
JWT_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-second-strong-secret
GEMINI_API_KEY=

# Optional
PORT=3333
NODE_ENV=development
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGINS=http://localhost:3000,https://next-level-front.vercel.app
TRUST_PROXY=1
FRONTEND_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3333
APP_URL=http://localhost:3333
GEMINI_MODEL=gemini-2.5-flash
REDIS_URL=redis://localhost:6379/0
BCRYPT_ROUNDS=12
PRISMA_CONNECT_RETRIES=5
PRISMA_CONNECT_RETRY_DELAY_MS=3000
SHOPIFY_WEBHOOK_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_AD_ACCOUNT_TO_COMPANY=
META_GRAPH_BASE_URL=https://graph.facebook.com
META_GRAPH_VERSION=20.0
MERCADOLIVRE_API_BASE_URL=https://api.mercadolibre.com
WHATSAPP_OAUTH_AUTHORIZE_URL=
WHATSAPP_OAUTH_CLIENT_ID=
WHATSAPP_OAUTH_SCOPE=whatsapp_business_management whatsapp_business_messaging
INSTAGRAM_OAUTH_AUTHORIZE_URL=
INSTAGRAM_OAUTH_CLIENT_ID=
INSTAGRAM_OAUTH_SCOPE=instagram_basic instagram_manage_messages pages_manage_metadata
MERCADOLIVRE_OAUTH_AUTHORIZE_URL=
MERCADOLIVRE_OAUTH_CLIENT_ID=
MERCADOLIVRE_OAUTH_SCOPE=offline_access read write
MERCADOPAGO_OAUTH_AUTHORIZE_URL=
MERCADOPAGO_OAUTH_CLIENT_ID=
MERCADOPAGO_OAUTH_SCOPE=offline_access payments
WPPCONNECT_SESSION=next-level-local
WPPCONNECT_HEADLESS=true
# MELHORIA: Auto-close desabilitado para produção (0 = desabilitado)
WPPCONNECT_AUTO_CLOSE=0
# MELHORIA: Retry automático com limite
WPPCONNECT_AUTO_RETRY=true
WPPCONNECT_RETRY_LIMIT=5

# Redis
# MELHORIA: Para Render.com, configurar política 'noeviction' no dashboard do Redis
# Ver REDIS_CONFIG.md para detalhes
REDIS_URL=redis://localhost:6379/0

# Prisma - Otimizações de conexão
# MELHORIA: Reduzido para 3 conexões máximas para evitar exhaustion no Render free tier
PRISMA_CONNECT_RETRIES=3
PRISMA_CONNECT_RETRY_DELAY_MS=1500

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback
FRONTEND_APP_URL=http://localhost:5173
