# Banco e aplicacao
DATABASE_URL="postgresql://user:password@localhost:5432/next_level_db?schema=public"
PORT=3333
NODE_ENV=development
APP_URL=http://localhost:3333
BACKEND_URL=http://localhost:3333
PUBLIC_API_URL=http://localhost:3333
FRONTEND_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://next-level-front.vercel.app
TRUST_PROXY=1

# Autenticacao
JWT_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-second-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Prisma
PRISMA_CONNECT_RETRIES=3
PRISMA_CONNECT_RETRY_DELAY_MS=1500

# Redis / filas
REDIS_URL=redis://localhost:6379/0

# IA
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_COMPLEX_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-4o
AI_PROVIDER_TIMEOUT_MS=20000
AI_PROVIDER_MAX_RETRIES=3

# Evolution API
EVOLUTION_BASE_URL=http://localhost:8081
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=replace-with-a-strong-evolution-key
EVOLUTION_WEBHOOK_SECRET=replace-with-a-dedicated-webhook-secret
EVOLUTION_API_TIMEOUT_MS=10000
EVOLUTION_API_MAX_RETRIES=2
EVOLUTION_API_INFO_TTL_MS=300000

# n8n / automacao interna
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=replace-with-your-n8n-api-key
N8N_WEBHOOK_URL=http://localhost:5678/webhook/evolution-webhook
N8N_INBOUND_WEBHOOK_URL=http://localhost:5678/webhook/evolution-webhook
INTERNAL_AUTOMATION_TOKEN=replace-with-a-strong-internal-token

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback

# Meta / webhooks oficiais
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_BASE_URL=https://graph.facebook.com
META_GRAPH_VERSION=20.0

# Integracoes opcionais
SHOPIFY_WEBHOOK_SECRET=
MERCADOLIVRE_API_BASE_URL=https://api.mercadolibre.com
