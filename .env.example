# Banco e aplicacao
DATABASE_URL="postgresql://user:password@localhost:5432/next_level_db?schema=public"
PORT=3333
NODE_ENV=development
APP_URL=http://localhost:3333
BACKEND_URL=http://localhost:3333
PUBLIC_API_URL=http://localhost:3333
FRONTEND_APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://next-level-front.vercel.app
TRUST_PROXY=1

# Autenticacao
JWT_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-second-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Prisma
PRISMA_CONNECT_RETRIES=3
PRISMA_CONNECT_RETRY_DELAY_MS=1500

# Redis / filas
REDIS_URL=redis://localhost:6379/0

# IA
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_COMPLEX_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-4o
AI_PROVIDER_TIMEOUT_MS=20000
AI_PROVIDER_MAX_RETRIES=3

# Evolution API
EVOLUTION_BASE_URL=http://localhost:8081
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=replace-with-a-strong-evolution-key
EVOLUTION_WEBHOOK_SECRET=replace-with-a-dedicated-webhook-secret
EVOLUTION_API_TIMEOUT_MS=10000
EVOLUTION_API_MAX_RETRIES=2
EVOLUTION_API_INFO_TTL_MS=300000

# n8n / automacao interna
# Evolution deve apontar eventos de ciclo de vida para BACKEND_URL/api/whatsapp/webhooks/evolution.
# N8N_WEBHOOK_URL e usado apenas para automacao de mensagens encaminhada pelo backend.
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=replace-with-your-n8n-api-key
N8N_WEBHOOK_URL=http://localhost:5678/webhook/evolution-webhook
N8N_INBOUND_WEBHOOK_URL=http://localhost:5678/webhook/evolution-webhook
INTERNAL_AUTOMATION_TOKEN=replace-with-a-strong-internal-token

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback

# Meta / webhooks oficiais
META_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=3641482999326328
META_APP_SECRET=
INTEGRATION_TOKEN_ENCRYPTION_KEY=
META_GRAPH_BASE_URL=https://graph.facebook.com
META_GRAPH_VERSION=20.0
INSTAGRAM_CLIENT_ID=3641482999326328
INSTAGRAM_REDIRECT_URI=https://next-level-backend.onrender.com/api/instagram/callback
INSTAGRAM_OAUTH_AUTHORIZE_URL=https://www.instagram.com/oauth/authorize
INSTAGRAM_OAUTH_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_OAUTH_SCOPE=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments
INSTAGRAM_OAUTH_EXTRA_PARAMS=enable_fb_login=0&force_authentication=1
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Integracoes opcionais
SHOPIFY_WEBHOOK_SECRET=
MERCADOLIVRE_API_BASE_URL=https://api.mercadolibre.com

# Billing provider
BILLING_PAYMENT_PROVIDER=CAKTO
BILLING_ADMIN_EMAILS=
BILLING_LEGACY_GRACE_ENABLED=false

# Cakto
CAKTO_API_BASE_URL=https://api.cakto.com.br
CAKTO_CLIENT_ID=
CAKTO_CLIENT_SECRET=
CAKTO_WEBHOOK_SECRET=
CAKTO_VERIFY_ORDER_ON_WEBHOOK=true
CAKTO_COMMON_MONTHLY_CHECKOUT_URL=
CAKTO_COMMON_ANNUAL_CHECKOUT_URL=
CAKTO_PREMIUM_MONTHLY_CHECKOUT_URL=
CAKTO_PREMIUM_ANNUAL_CHECKOUT_URL=
CAKTO_PRO_BUSINESS_MONTHLY_CHECKOUT_URL=
CAKTO_PRO_BUSINESS_ANNUAL_CHECKOUT_URL=
CAKTO_COMMON_MONTHLY_PRODUCT_ID=
CAKTO_COMMON_MONTHLY_OFFER_ID=
CAKTO_COMMON_ANNUAL_PRODUCT_ID=
CAKTO_COMMON_ANNUAL_OFFER_ID=
CAKTO_PREMIUM_MONTHLY_PRODUCT_ID=
CAKTO_PREMIUM_MONTHLY_OFFER_ID=
CAKTO_PREMIUM_ANNUAL_PRODUCT_ID=
CAKTO_PREMIUM_ANNUAL_OFFER_ID=
CAKTO_PRO_BUSINESS_MONTHLY_PRODUCT_ID=
CAKTO_PRO_BUSINESS_MONTHLY_OFFER_ID=
CAKTO_PRO_BUSINESS_ANNUAL_PRODUCT_ID=
CAKTO_PRO_BUSINESS_ANNUAL_OFFER_ID=

# AbacatePay legado, opcional quando BILLING_PAYMENT_PROVIDER=CAKTO
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_WEBHOOK_PUBLIC_KEY=
ABACATEPAY_API_BASE_URL=https://api.abacatepay.com/v2
ABACATEPAY_SUBSCRIPTION_METHODS=CARD
ABACATEPAY_ENABLE_PIX_SUBSCRIPTIONS=false
ABACATEPAY_COMMON_MONTHLY_PRODUCT_ID=
ABACATEPAY_COMMON_ANNUAL_PRODUCT_ID=
ABACATEPAY_PREMIUM_MONTHLY_PRODUCT_ID=
ABACATEPAY_PREMIUM_ANNUAL_PRODUCT_ID=
ABACATEPAY_PRO_BUSINESS_MONTHLY_PRODUCT_ID=
ABACATEPAY_PRO_BUSINESS_ANNUAL_PRODUCT_ID=
PLAN_COMMON_MONTHLY_CENTS=4990
PLAN_COMMON_ANNUAL_CENTS=49900
PLAN_PREMIUM_MONTHLY_CENTS=9700
PLAN_PREMIUM_ANNUAL_CENTS=97000
PLAN_PRO_BUSINESS_MONTHLY_CENTS=19700
PLAN_PRO_BUSINESS_ANNUAL_CENTS=197000
