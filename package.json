{
  "name": "next-level-backend",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "prisma migrate deploy && node dist/main.js",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1",
    "test:integration": "powershell -ExecutionPolicy Bypass -File scripts/integration-test.ps1",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.22",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/client": "^5.22.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@wppconnect-team/wppconnect": "^1.41.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns-tz": "^3.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "openai": "^6.17.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.18.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
