generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  COMUM
  PRO
  ENTERPRISE
}

enum UserNiche {
  ECOMMERCE
  MEDICINA
  SERVICOS
  EDUCACAO
  OUTROS
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
}

enum AiChatRole {
  USER
  ASSISTANT
}

enum IntegrationProvider {
  WHATSAPP
  INSTAGRAM
  MERCADOLIVRE
  SHOPEE
}

enum ForecastType {
  SALES
  DEMAND
  REVENUE
}

enum StrategicActionType {
  MARKETING
  ESTOQUE
  FINANCEIRO
}

enum StrategicActionStatus {
  SUGGESTED
  APPROVED
  EXECUTED
  REJECTED
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  LOST
}

enum SaleAIAttributionSource {
  WHATSAPP_AGENT
  INSTAGRAM_AGENT
  CHAT_IA
  MANUAL_REVIEW
  IMPORTED
  UNKNOWN
}

enum ActorType {
  HUMAN
  AI
  SYSTEM
}

enum WebhookLogStatus {
  SUCCESS
  FAILED
}

enum WhatsappInstanceStatus {
  DISCONNECTED
  CONNECTING
  QR_READY
  CONNECTED
  ERROR
}

enum WhatsappMessageProcessStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum CsvImportDataType {
  SALES
  PRODUCTS
  CUSTOMERS
  COSTS
  AD_SPEND
  ORDERS
}

enum CsvImportStatus {
  UPLOADED
  MAPPED
  PROCESSING
  COMPLETED
  FAILED
}

enum IntelligentImportInputType {
  IMAGE
  PDF
  CSV
  TEXT
  DOCUMENT
}

enum IntelligentImportStatus {
  UPLOADED
  ANALYZING
  NEEDS_REVIEW
  CONFIRMED
  REJECTED
  FAILED
}

enum IntelligentImportCategory {
  MARKETING
  DELIVERY
  MARKETPLACE
  FINANCIAL
  PRODUCTS
  CUSTOMERS
  MIXED
  UNKNOWN
}

enum ImportedMetricUnit {
  CURRENCY
  PERCENTAGE
  COUNT
  RATIO
  TEXT
}

enum ImportedMetricSource {
  AI_IMPORT
  CSV_IMPORT
  MANUAL_TEXT
  SCREENSHOT
  PDF
}

enum ImportedMetricStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum ImportedEntityType {
  PRODUCT
  CUSTOMER
  ORDER
  ORDER_ITEM
  CAMPAIGN
  AD
  COST
  UNKNOWN
}

enum ImportedEntityStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum AIUsageFeature {
  CHAT_IA             @map("chat_ia")
  WHATSAPP_AGENT      @map("whatsapp_agent")
  IMAGE_ANALYSIS      @map("image_analysis")
  AUDIO_TRANSCRIPTION @map("audio_transcription")
  WEB_SEARCH          @map("web_search")
  REPORT_GENERATION   @map("report_generation")
  INTELLIGENT_IMPORT  @map("intelligent_import")
  OTHER               @map("other")
}

enum AIUsageProvider {
  GEMINI   @map("gemini")
  OPENAI   @map("openai")
  INTERNAL @map("internal")
  UNKNOWN  @map("unknown")
}

enum AIUsageStatus {
  SUCCESS @map("success")
  FAILED  @map("failed")
  BLOCKED @map("blocked")
}

model Company {
  id                   String    @id @default(cuid())
  userId               String?
  name                 String
  sector               String?
  segment              String?
  document             String?
  description          String?
  openedAt             DateTime?
  slug                 String    @unique @default(cuid())
  currency             String    @default("BRL")
  timezone             String    @default("America/Sao_Paulo")
  defaultTaxRate       Decimal?  @db.Decimal(5, 2)
  metaPhoneNumberId    String?
  metaWabaId           String?
  whatsappBusinessId   String?
  metaAccessToken      String?   @db.Text
  webhookVerifyToken   String?
  phoneNumber          String?
  lastConnectedAt      DateTime?
  evolutionConnected   Boolean   @default(false)
  instagramAccountId   String?
  shopeeShopId         String?
  shopeeUser           String?
  shopeePass           String?
  shopeeAccessToken    String?
  shopeeRefreshToken   String?
  shopeeTokenExpiresAt DateTime?
  shopeeCookies        String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users                 User[]
  sales                 Sale[]
  saleAIAttributions    SaleAIAttribution[]
  adSpends              AdSpend[]
  financialTransactions FinancialTransaction[]
  aiChatMessages        AiChatMessage[]
  products              Product[]
  customers             Customer[]
  operationalCosts      OperationalCost[]
  integrations          Integration[]
  webhookEvents         WebhookEvent[]
  webhookLogs           WebhookLog[]
  alerts                Alert[]
  forecastSnapshots     ForecastSnapshot[]
  strategicActions      StrategicAction[]
  competitors           Competitor[]
  marketPrices          MarketPrice[]
  marketTrends          MarketTrend[]
  botConfig             BotConfig?
  agentConfig           AgentConfig?
  leads                 Lead[]
  conversations         Conversation[]
  messages              Message[]
  usageQuota            UsageQuota?
  apiLogs               ApiLog[]
  auditTrails           AuditTrail[]
  whatsappInstance      WhatsappInstance?
  whatsappConnection    WhatsappConnection?
  whatsappMessageEvents WhatsappMessageEvent[]
  dashboardPreferences  DashboardPreference[]
  companyProfile        CompanyProfile?
  modulePreferences     CompanyModulePreference[]
  csvImportJobs         CsvImportJob[]
  intelligentImports    IntelligentImport[]
  importedMetrics       ImportedMetric[]
  importedEntities      ImportedEntity[]
  aiUsageLogs           AIUsageLog[]
  aiUsageMonthly        CompanyAIUsageMonthly[]
  businessEvents        BusinessEvent[]
  aiInsights            AiInsight[]
  aiAlerts              AiAlert[]
  businessMemories      BusinessMemory[]
  customerSignals       CustomerSignal[]
  conversationAnalyses  ConversationAnalysis[]
  aiRecommendations     AiRecommendation[]
}

model AdSpend {
  id        String   @id @default(cuid())
  companyId String
  amount    Decimal  @db.Decimal(12, 2)
  spentAt   DateTime
  source    String   @default("meta")
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, spentAt])
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String?
  googleId    String?    @unique
  plan        Plan       @default(COMUM)
  admin       Boolean    @default(false)
  detailLevel String     @default("medium")
  niche       UserNiche?
  name        String?
  companyId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company               Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sales                 Sale[]
  analyses              Analysis[]
  financialTransactions FinancialTransaction[]
  aiChatMessages        AiChatMessage[]
  refreshTokens         RefreshToken[]
  intelligentImports    IntelligentImport[]
  aiUsageLogs           AIUsageLog[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// Canal de origem da venda. manual = criada pelo usuário; shopify/meta = futuros webhooks.
enum SaleChannel {
  manual
  shopify
  meta
}

model Sale {
  id          String      @id @default(cuid())
  userId      String?
  companyId   String
  amount      Decimal     @db.Decimal(12, 2)
  productName String? // Nome do produto (ou use category para agrupamento)
  category    String? // Categoria opcional para agrupamento no dashboard
  channel     SaleChannel @default(manual) // manual | shopify | meta
  occurredAt  DateTime // Timestamp real da venda (não o created_at)
  createdAt   DateTime    @default(now())

  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiAttribution SaleAIAttribution?

  @@index([userId])
  @@index([userId, occurredAt])
  @@index([companyId])
  @@index([companyId, occurredAt])
}

model SaleAIAttribution {
  id                String                  @id @default(cuid())
  companyId         String
  saleId            String                  @unique
  conversationId    String?
  leadId            String?
  messageId         String?
  source            SaleAIAttributionSource @default(WHATSAPP_AGENT)
  attributedRevenue Decimal                 @db.Decimal(12, 2)
  confidence        Float                   @default(1)
  metadataJson      Json?
  occurredAt        DateTime
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale         Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([companyId, source, occurredAt])
  @@index([conversationId])
  @@index([leadId])
  @@index([messageId])
}

model Analysis {
  id        String   @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model FinancialTransaction {
  id          String                   @id @default(cuid())
  companyId   String
  userId      String
  type        FinancialTransactionType
  amount      Decimal                  @db.Decimal(12, 2)
  description String
  category    String?
  date        DateTime                 @default(now())
  occurredAt  DateTime
  createdAt   DateTime                 @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([occurredAt])
  @@index([companyId, occurredAt])
}

model AiChatMessage {
  id         String     @id @default(cuid())
  userId     String
  companyId  String
  role       AiChatRole
  content    String
  tokensUsed Int?
  createdAt  DateTime   @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sku       String?
  category  String?
  price     Decimal  @db.Decimal(12, 2)
  cost      Decimal? @db.Decimal(12, 2)
  /// Impostos/tributos estimados por unidade (opcional, para margem real)
  tax       Decimal? @db.Decimal(12, 2)
  /// Frete/logística estimado por unidade (opcional)
  shipping  Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  marketPrices MarketPrice[]

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, sku])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  signals              CustomerSignal[]
  conversationAnalyses ConversationAnalysis[]

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, email])
}

model OperationalCost {
  id        String   @id @default(cuid())
  companyId String
  name      String
  category  String?
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, category])
}

model Integration {
  id           String              @id @default(cuid())
  companyId    String
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  externalId   String
  status       String              @default("connected")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@unique([provider, externalId])
  @@index([companyId, provider])
}

model WebhookEvent {
  id        String              @id @default(cuid())
  companyId String?
  provider  IntegrationProvider
  payload   Json
  processed Boolean             @default(false)
  createdAt DateTime            @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([companyId])
}

model WebhookLog {
  id        String              @id @default(cuid())
  companyId String?
  provider  IntegrationProvider
  status    WebhookLogStatus    @default(SUCCESS)
  message   String?
  eventId   String?
  createdAt DateTime            @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([provider, status, createdAt])
  @@index([companyId, provider, createdAt])
}

model Alert {
  id        String   @id @default(cuid())
  companyId String
  type      String
  message   String
  severity  String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ForecastSnapshot {
  id            String       @id @default(cuid())
  companyId     String
  type          ForecastType
  data          Json
  accuracyScore Float        @default(0)
  createdAt     DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
  @@index([createdAt])
}

model StrategicAction {
  id          String                @id @default(cuid())
  companyId   String
  title       String
  description String
  type        StrategicActionType
  status      StrategicActionStatus @default(SUGGESTED)
  impactScore Int                   @default(50)
  payload     Json
  createdAt   DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([companyId, type])
}

model BotConfig {
  id                String   @id @default(cuid())
  companyId         String   @unique
  botName           String   @default("Atendente IA")
  welcomeMessage    String?
  toneOfVoice       String   @default("amigavel")
  instructions      String?
  isActive          Boolean  @default(true)
  messageQuotaUsed  Int      @default(0)
  messageQuotaLimit Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AgentConfig {
  id                        String   @id @default(cuid())
  companyId                 String   @unique
  agentName                 String   @default("Atendente")
  companyDescription        String   @default("") @db.Text
  tone                      String   @default("Amigável")
  welcomeMessage            String   @default("") @db.Text
  instructions              String   @default("") @db.Text
  systemPrompt              String   @default("") @db.Text
  toneOfVoice               String   @default("consultivo")
  internetSearchEnabled     Boolean  @default(false)
  speechToTextEnabled       Boolean  @default(false)
  imageUnderstandingEnabled Boolean  @default(false)
  pauseForHuman             Boolean  @default(true)
  debounceSeconds           Int      @default(3)
  maxContextMessages        Int      @default(20)
  splitRepliesEnabled       Boolean  @default(false)
  messageBufferEnabled      Boolean  @default(true)
  isEnabled                 Boolean  @default(false)
  modelProvider             String   @default("openai")
  modelName                 String   @default("gpt-4o-mini")
  isOnline                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WhatsappConnection {
  id                      String    @id @default(cuid())
  companyId               String    @unique
  provider                String    @default("evolution")
  instanceName            String    @unique
  instanceId              String?
  instanceToken           String?   @db.Text
  status                  String    @default("not_configured")
  connectionState         String    @default("close")
  qrCode                  String?   @db.Text
  qrCodeText              String?   @db.Text
  pairingCode             String?
  phoneNumber             String?
  webhookUrl              String?   @db.Text
  webhookEnabled          Boolean   @default(false)
  webhookLastConfiguredAt DateTime?
  webhookLastError        String?   @db.Text
  webhookConfigHash       String?
  userRequestedDisconnect Boolean   @default(false)
  sessionGeneration       Int       @default(1)
  lastEvolutionState      String?
  lastConnectionEventAt   DateTime?
  lastQrAt                DateTime?
  lastQrGeneratedAt       DateTime?
  lastError               String?   @db.Text
  lastConnectionAt        DateTime?
  lastConnectedAt         DateTime?
  lastDisconnectedAt      DateTime?
  lastEvolutionSyncAt     DateTime?
  lastConnectStartAt      DateTime?
  lastQrRequestAt         DateTime?
  lastRepairAt            DateTime?
  providerRetryAfterUntil DateTime?
  operationLockUntil      DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([companyId, status])
  @@index([status, updatedAt])
}

model Conversation {
  id                   String                 @id @default(cuid())
  companyId            String
  whatsappConnectionId String?
  contactNumber        String
  remoteJid            String?
  contactName          String?
  status               String                 @default("Aguardando")
  isPaused             Boolean                @default(false)
  botPaused            Boolean                @default(false)
  pausedUntil          DateTime?
  lastMessagePreview   String?                @db.Text
  lastMessageAt        DateTime               @default(now())
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  messages             Message[]
  saleAIAttributions   SaleAIAttribution[]
  analyses             ConversationAnalysis[]
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  whatsappConnection   WhatsappConnection?    @relation(fields: [whatsappConnectionId], references: [id], onDelete: SetNull)

  @@unique([companyId, contactNumber])
  @@index([whatsappConnectionId])
  @@index([companyId, remoteJid])
  @@index([companyId, updatedAt])
  @@index([companyId, isPaused])
}

model Message {
  id                 String              @id @default(cuid())
  companyId          String
  conversationId     String
  externalMessageId  String?
  content            String              @default("") @db.Text
  role               String              @default("user")
  direction          String              @default("inbound")
  contentType        String              @default("text")
  text               String?             @db.Text
  transcription      String?             @db.Text
  mediaUrl           String?             @db.Text
  aiResponse         String?             @db.Text
  senderName         String?
  senderPhone        String?
  status             String              @default("received")
  metadata           Json?
  rawPayload         Json?
  timestamp          DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation       Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  saleAIAttributions SaleAIAttribution[]

  @@unique([conversationId, externalMessageId])
  @@index([companyId, createdAt])
  @@index([conversationId, createdAt])
  @@index([conversationId, timestamp])
}

model Lead {
  id              String     @id @default(cuid())
  companyId       String
  externalId      String
  name            String?
  status          LeadStatus @default(NEW)
  score           Int        @default(0)
  lastInteraction DateTime?
  botPausedUntil  DateTime?
  lastQuotedValue Decimal?   @db.Decimal(12, 2)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations      ChatConversation[]
  saleAIAttributions SaleAIAttribution[]

  @@unique([companyId, externalId])
  @@index([companyId, status])
}

model ChatConversation {
  id        String     @id @default(cuid())
  leadId    String
  role      AiChatRole
  content   String
  createdAt DateTime   @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model UsageQuota {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  llmTokensUsed        Int      @default(0)
  whatsappMessagesSent Int      @default(0)
  currentTier          Plan     @default(COMUM)
  billingCycleEnd      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([updatedAt])
}

model AIUsageLog {
  id            String          @id @default(cuid())
  companyId     String
  userId        String?
  feature       AIUsageFeature
  provider      AIUsageProvider @default(UNKNOWN)
  model         String?
  inputTokens   Int?
  outputTokens  Int?
  totalTokens   Int?
  requestCount  Int             @default(1)
  estimatedCost Decimal?        @db.Decimal(12, 6)
  status        AIUsageStatus
  errorMessage  String?         @db.Text
  metadataJson  Json?
  createdAt     DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, feature, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AIUsageLimit {
  id                  String         @id @default(cuid())
  planKey             String
  feature             AIUsageFeature
  monthlyRequestLimit Int?
  monthlyTokenLimit   Int?
  enabled             Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([planKey, feature])
  @@index([planKey])
}

model CompanyAIUsageMonthly {
  id            String         @id @default(cuid())
  companyId     String
  yearMonth     String
  feature       AIUsageFeature
  requestCount  Int            @default(0)
  tokenCount    Int            @default(0)
  estimatedCost Decimal        @default(0) @db.Decimal(12, 6)
  updatedAt     DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, yearMonth, feature])
  @@index([companyId, yearMonth])
  @@index([feature, yearMonth])
}

model ApiLog {
  id           String   @id @default(cuid())
  method       String
  path         String
  statusCode   Int
  responseTime Int
  status       String?
  provider     String?
  errorMessage String?
  companyId    String?
  payload      Json?
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([statusCode, createdAt])
}

model AuditTrail {
  id        String    @id @default(cuid())
  companyId String?
  actorType ActorType @default(SYSTEM)
  actorId   String?
  action    String
  details   Json?
  createdAt DateTime  @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model Competitor {
  id        String   @id @default(cuid())
  companyId String
  name      String
  url       String
  category  String?
  createdAt DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  marketPrices MarketPrice[]

  @@unique([companyId, name])
  @@index([companyId, category])
}

model MarketPrice {
  id           String   @id @default(cuid())
  companyId    String
  productId    String
  competitorId String
  price        Decimal  @db.Decimal(12, 2)
  url          String?
  createdAt    DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([companyId, productId])
  @@index([productId])
  @@index([competitorId, createdAt])
  @@index([companyId, createdAt])
}

model MarketTrend {
  id               String   @id @default(cuid())
  companyId        String
  term             String
  volume           Int      @default(0)
  growthPercentage Float    @default(0)
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, term, createdAt])
  @@index([companyId, createdAt])
}

model WhatsappInstance {
  id               String                 @id @default(cuid())
  companyId        String                 @unique
  instanceName     String                 @unique
  webhookTokenHash String
  status           WhatsappInstanceStatus @default(DISCONNECTED)
  connectionState  String                 @default("close")
  qrCode           String?                @db.Text
  pairingCode      String?
  phoneNumber      String?
  lastConnectionAt DateTime?
  lastWebhookAt    DateTime?
  lastError        String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messageEvents WhatsappMessageEvent[]

  @@index([status, updatedAt])
}

model WhatsappMessageEvent {
  id                String                       @id @default(cuid())
  companyId         String
  instanceId        String
  externalMessageId String
  remoteJid         String
  remoteNumber      String
  pushName          String?
  messageType       String?
  text              String?                      @db.Text
  fromMe            Boolean                      @default(false)
  eventName         String
  messageTimestamp  DateTime?
  status            WhatsappMessageProcessStatus @default(PENDING)
  errorMessage      String?                      @db.Text
  rawPayload        Json
  processedAt       DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instance WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalMessageId])
  @@index([companyId, status, createdAt])
  @@index([companyId, remoteNumber, createdAt])
  @@index([instanceId, createdAt])
}

model DashboardPreference {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  metricKey String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  size      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, metricKey])
  @@index([companyId])
}

model CompanyProfile {
  id                          String    @id @default(cuid())
  companyId                   String    @unique
  businessType                String
  businessModel               String?
  mainGoal                    String?
  salesChannel                String?
  companySize                 String?
  monthlyRevenueRange         String?
  dataMaturity                String?
  originalBusinessDescription String?
  detectedBusinessType        String?
  classificationConfidence    Float?
  usesPaidTraffic             Boolean   @default(false)
  hasPhysicalProducts         Boolean   @default(false)
  hasDigitalProducts          Boolean   @default(false)
  hasServices                 Boolean   @default(false)
  usesWhatsAppForSales        Boolean   @default(false)
  usesMarketplace             Boolean   @default(false)
  hasSupportTeam              Boolean   @default(false)
  hasOperationalCosts         Boolean   @default(false)
  wantsAutomation             Boolean   @default(false)
  wantsMarketAnalysis         Boolean   @default(false)
  onboardingCompleted         Boolean   @default(false)
  onboardingSkipped           Boolean   @default(false)
  completedAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyModulePreference {
  id        String   @id @default(cuid())
  companyId String
  moduleKey String
  enabled   Boolean  @default(true)
  source    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleKey])
  @@index([companyId])
}

model CsvImportJob {
  id              String            @id @default(cuid())
  companyId       String
  dataType        CsvImportDataType
  fileName        String
  status          CsvImportStatus   @default(UPLOADED)
  totalRows       Int               @default(0)
  importedRows    Int               @default(0)
  failedRows      Int               @default(0)
  mappingJson     Json?
  previewRowsJson Json?
  rawCsvText      String?           @db.Text
  errorJson       Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rowErrors CsvImportRowError[]

  @@index([companyId, createdAt])
  @@index([companyId, status])
}

model CsvImportRowError {
  id           String   @id @default(cuid())
  importJobId  String
  rowNumber    Int
  errorMessage String   @db.Text
  rawRowJson   Json
  createdAt    DateTime @default(now())

  importJob CsvImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([importJobId, rowNumber])
}

model IntelligentImport {
  id                  String                     @id @default(cuid())
  companyId           String
  userId              String
  inputType           IntelligentImportInputType
  fileName            String?
  fileMimeType        String?
  fileSize            Int?
  fileUrl             String?
  storageKey          String?
  pastedText          String?                    @db.Text
  rawContentText      String?                    @db.Text
  previewJson         Json?
  expectedCategory    String?
  detectedCategory    IntelligentImportCategory?
  detectedPlatform    String?
  detectedPeriodStart DateTime?
  detectedPeriodEnd   DateTime?
  confidence          Float                      @default(0)
  status              IntelligentImportStatus    @default(UPLOADED)
  aiSummary           String?                    @db.Text
  extractedJson       Json?
  warningsJson        Json?
  errorMessage        String?                    @db.Text
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  confirmedAt         DateTime?

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedMetrics  ImportedMetric[]
  importedEntities ImportedEntity[]

  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([companyId, detectedCategory])
}

model ImportedMetric {
  id           String               @id @default(cuid())
  companyId    String
  importId     String
  metricKey    String
  label        String
  value        Json
  unit         ImportedMetricUnit
  currency     String?              @default("BRL")
  periodStart  DateTime?
  periodEnd    DateTime?
  source       ImportedMetricSource
  platform     String?
  confidence   Float                @default(0)
  status       ImportedMetricStatus @default(PENDING_REVIEW)
  metadataJson Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  import  IntelligentImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([companyId, metricKey, status])
  @@index([importId])
}

model ImportedEntity {
  id             String               @id @default(cuid())
  companyId      String
  importId       String
  entityType     ImportedEntityType
  normalizedJson Json
  confidence     Float                @default(0)
  status         ImportedEntityStatus @default(PENDING_REVIEW)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  import  IntelligentImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([companyId, entityType, status])
  @@index([importId])
}

model BusinessEvent {
  id           String   @id @default(cuid())
  companyId    String
  source       String
  type         String
  title        String
  description  String?  @db.Text
  metadataJson Json?
  occurredAt   DateTime
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, occurredAt])
  @@index([companyId, source, type])
}

model AiInsight {
  id             String   @id @default(cuid())
  companyId      String
  type           String
  title          String
  summary        String   @db.Text
  impact         String?
  recommendation String?  @db.Text
  priority       String   @default("medium")
  source         String
  metadataJson   Json?
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, type, priority])
}

model AiAlert {
  id             String    @id @default(cuid())
  companyId      String
  type           String
  severity       String
  title          String
  message        String    @db.Text
  recommendation String?   @db.Text
  status         String    @default("open")
  metadataJson   Json?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([companyId, type, severity])
}

model BusinessMemory {
  id           String   @id @default(cuid())
  companyId    String
  key          String
  value        String   @db.Text
  category     String
  confidence   Float    @default(1)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId, category])
}

model CustomerSignal {
  id           String   @id @default(cuid())
  companyId    String
  customerId   String?
  source       String
  signalType   String
  description  String   @db.Text
  metadataJson Json?
  createdAt    DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, signalType])
  @@index([customerId])
}

model ConversationAnalysis {
  id                String   @id @default(cuid())
  companyId         String
  conversationId    String
  customerId        String?
  intent            String?
  sentiment         String?
  productsMentioned Json?
  objections        Json?
  buyingIntent      String?
  summary           String   @db.Text
  recommendedAction String?  @db.Text
  metadataJson      Json?
  createdAt         DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, conversationId])
  @@index([companyId, buyingIntent])
}

model AiRecommendation {
  id             String   @id @default(cuid())
  companyId      String
  category       String
  title          String
  description    String   @db.Text
  expectedImpact String?
  actionType     String
  status         String   @default("suggested")
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([companyId, category])
}
