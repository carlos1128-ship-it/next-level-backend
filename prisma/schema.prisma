generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
}

enum AiChatRole {
  USER
  ASSISTANT
}

enum IntegrationProvider {
  WHATSAPP
  INSTAGRAM
  MERCADOLIVRE
}

enum ForecastType {
  SALES
  DEMAND
  REVENUE
}

enum StrategicActionType {
  MARKETING
  ESTOQUE
  FINANCEIRO
}

enum StrategicActionStatus {
  SUGGESTED
  APPROVED
  EXECUTED
  REJECTED
}

model Company {
  id          String    @id @default(cuid())
  userId      String?
  name        String
  sector      String?
  segment     String?
  document    String?
  description String?
  openedAt    DateTime?
  slug        String    @unique @default(cuid())
  currency    String    @default("BRL")
  timezone    String    @default("America/Sao_Paulo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users    User[]
  sales    Sale[]
  adSpends AdSpend[]
  financialTransactions FinancialTransaction[]
  aiChatMessages       AiChatMessage[]
  products            Product[]
  customers           Customer[]
  operationalCosts    OperationalCost[]
  integrations        Integration[]
  webhookEvents       WebhookEvent[]
  alerts              Alert[]
  forecastSnapshots   ForecastSnapshot[]
  strategicActions    StrategicAction[]
}

model AdSpend {
  id        String   @id @default(cuid())
  companyId String
  amount    Decimal  @db.Decimal(12, 2)
  spentAt   DateTime
  source    String   @default("meta")
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, spentAt])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  plan      Plan     @default(FREE)
  detailLevel String @default("medium")
  name      String?
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company?               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales                Sale[]
  analyses             Analysis[]
  financialTransactions FinancialTransaction[]
  aiChatMessages       AiChatMessage[]
  refreshTokens        RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// Canal de origem da venda. manual = criada pelo usuário; shopify/meta = futuros webhooks.
enum SaleChannel {
  manual
  shopify
  meta
}

model Sale {
  id          String      @id @default(cuid())
  userId      String?
  companyId   String
  amount      Decimal     @db.Decimal(12, 2)
  productName String?     // Nome do produto (ou use category para agrupamento)
  category    String?     // Categoria opcional para agrupamento no dashboard
  channel     SaleChannel @default(manual) // manual | shopify | meta
  occurredAt  DateTime    // Timestamp real da venda (não o created_at)
  createdAt   DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, occurredAt])
  @@index([companyId])
  @@index([companyId, occurredAt])
}

model Analysis {
  id        String   @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model FinancialTransaction {
  id          String                   @id @default(cuid())
  companyId   String
  userId      String
  type        FinancialTransactionType
  amount      Decimal                  @db.Decimal(12, 2)
  description String
  category    String?
  date        DateTime                 @default(now())
  occurredAt  DateTime
  createdAt   DateTime                 @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([occurredAt])
  @@index([companyId, occurredAt])
}

model AiChatMessage {
  id         String    @id @default(cuid())
  userId     String
  companyId  String
  role       AiChatRole
  content    String
  tokensUsed Int?
  createdAt  DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sku       String?
  category  String?
  price     Decimal  @db.Decimal(12, 2)
  cost      Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, sku])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, email])
}

model OperationalCost {
  id        String   @id @default(cuid())
  companyId String
  name      String
  category  String?
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, category])
}

model Integration {
  id          String               @id @default(cuid())
  companyId   String
  provider    IntegrationProvider
  accessToken String
  externalId  String
  status      String               @default("connected")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, provider])
  @@unique([companyId, provider])
  @@unique([provider, externalId])
}

model WebhookEvent {
  id        String               @id @default(cuid())
  companyId String?
  provider  IntegrationProvider
  payload   Json
  processed Boolean              @default(false)
  createdAt DateTime             @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([companyId])
}

model Alert {
  id        String   @id @default(cuid())
  companyId String
  type      String
  message   String
  severity  String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ForecastSnapshot {
  id            String        @id @default(cuid())
  companyId     String
  type          ForecastType
  data          Json
  accuracyScore Float         @default(0)
  createdAt     DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type])
  @@index([createdAt])
}

model StrategicAction {
  id           String                @id @default(cuid())
  companyId    String
  title        String
  description  String
  type         StrategicActionType
  status       StrategicActionStatus @default(SUGGESTED)
  impactScore  Int                   @default(50)
  payload      Json
  createdAt    DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([companyId, type])
}
